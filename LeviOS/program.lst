   175 0000011B 240F                <1>     and al, 0x0F        ; Mask out high bits to get low nibble
   176 0000011D E80B00              <1>     call .nibble_to_char
   177 00000120 8804                <1>     mov [si], al
   178 00000122 46                  <1>     inc si
